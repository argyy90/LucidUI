<Ui xmlns="http://www.blizzard.com/wow/ui/"
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
   xsi:schemaLocation="http://www.blizzard.com/wow/ui/
   https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">

  <!--
    LucidUI Hyperlink Handler
    Plain ScrollingMessageFrame — no ChatFrameTemplate to avoid Blizzard chrome errors.
    Used as parent for the chat display so hyperlinks propagate up via
    SetHyperlinkPropagateToParent(true). URL clicks intercepted via
    EventRegistry:RegisterCallback("SetItemRef") in ChatFormat.lua.
  -->
  <ScrollingMessageFrame
    name="LucidUIHyperlinkFrame"
    parent="UIParent"
    hyperlinksEnabled="true"
    hidden="true">
  </ScrollingMessageFrame>

</Ui>
